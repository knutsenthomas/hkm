{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/category/all-products", "destination": "https://www.hiskingdomdesigns.no/", "permanent": true },
    { "source": "/category/cups-bottles", "destination": "https://www.hiskingdomdesigns.no/", "permanent": true },
    { "source": "/category/:path*", "destination": "https://www.hiskingdomdesigns.no/", "permanent": true },
    { "source": "/kontakt-oss", "destination": "/kontakt", "permanent": true },
    { "source": "/hvem-vi-er", "destination": "/om-oss", "permanent": true },
    { "source": "/butikk", "destination": "https://www.hiskingdomdesigns.no/", "permanent": true },
    { "source": "/butikk.html", "destination": "https://www.hiskingdomdesigns.no/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/api/bible/:path*", "destination": "/api/bible" },
    { "source": "/leseplan-detaljer", "destination": "/api/share-preview?lang=no" },
    { "source": "/leseplan-detaljer.html", "destination": "/api/share-preview?lang=no" },
    { "source": "/en/reading-plan-details", "destination": "/api/share-preview?lang=en" },
    { "source": "/en/reading-plan-details.html", "destination": "/api/share-preview?lang=en" },
    { "source": "/es/detalles-plan-lectura", "destination": "/api/share-preview?lang=es" },
    { "source": "/es/detalles-plan-lectura.html", "destination": "/api/share-preview?lang=es" },
    { "source": "/en/blog", "destination": "/en/blog.html" },
    { "source": "/en/blog-post", "destination": "/en/blog-post.html" },
    { "source": "/es/blog", "destination": "/es/blog.html" },
    { "source": "/es/blog-post", "destination": "/es/blog-post.html" }
  ],
  "functions": {
    "api/share-preview.js": {
      "includeFiles": [
        "dist/leseplan-detaljer-template.html",
        "dist/en/reading-plan-details-template.html",
        "dist/es/detalles-plan-lectura-template.html"
      ]
    }
  }
}


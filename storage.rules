rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isSignedIn() {
      return request.auth != null;
    }

    function userDocPath() {
      return /databases/(default)/documents/users/$(request.auth.uid);
    }

    function hasUserDoc() {
      return isSignedIn() && firestore.exists(userDocPath());
    }

    function currentUserRole() {
      return hasUserDoc()
        ? firestore.get(userDocPath()).data.role
        : null;
    }

    function isPrivilegedUser() {
      return isSignedIn()
        && (
          currentUserRole() == 'editor'
          || currentUserRole() == 'admin'
          || currentUserRole() == 'superadmin'
        );
    }

    function isOwnProfile(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isImageUpload() {
      return request.resource != null
        && request.resource.size < 10 * 1024 * 1024
        && request.resource.contentType != null
        && request.resource.contentType.matches('image/.*');
    }

    function isVisitorChatMediaUpload() {
      return request.resource != null
        && request.resource.size < 50 * 1024 * 1024
        && request.resource.contentType != null
        && (
          request.resource.contentType.matches('image/.*')
          || request.resource.contentType.matches('video/.*')
        );
    }

    function isInboxEmailAttachmentUpload() {
      return request.resource != null
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType != null;
    }

    match /profiles/{userId}/{allPaths=**} {
      allow read: if isOwnProfile(userId) || isPrivilegedUser();
      allow write: if isImageUpload() && (isOwnProfile(userId) || isPrivilegedUser());
    }

    match /editor/{allPaths=**} {
      allow read: if true;
      allow write: if isImageUpload() && isPrivilegedUser();
    }

    match /editor/visitor-chat/{allPaths=**} {
      allow read: if true;
      allow write: if isVisitorChatMediaUpload() && isPrivilegedUser();
    }

    match /editor/inbox-email/{allPaths=**} {
      allow read: if true;
      allow write: if isInboxEmailAttachmentUpload() && isPrivilegedUser();
    }

    match /covers/{allPaths=**} {
      allow read: if true;
      allow write: if isImageUpload() && isPrivilegedUser();
    }

    match /hero/{allPaths=**} {
      allow read: if true;
      allow write: if isImageUpload() && isPrivilegedUser();
    }

    match /seo/{allPaths=**} {
      allow read: if true;
      allow write: if isImageUpload() && isPrivilegedUser();
    }

    match /newsletter/images/{allPaths=**} {
      allow read: if true;
      allow write: if isImageUpload() && isPrivilegedUser();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

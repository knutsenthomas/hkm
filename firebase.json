{
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log"
      ]
    }
  ],
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "public",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "cleanUrls": true,
    "redirects": [
      { "source": "/category/all-products", "destination": "https://www.hiskingdomdesigns.no/", "type": 301 },
      { "source": "/category/cups-bottles", "destination": "https://www.hiskingdomdesigns.no/", "type": 301 },
      { "source": "/category/:path*", "destination": "https://www.hiskingdomdesigns.no/", "type": 301 },
      { "source": "/kontakt-oss", "destination": "/kontakt", "type": 301 },
      { "source": "/hvem-vi-er", "destination": "/om-oss", "type": 301 },
      { "source": "/butikk", "destination": "https://www.hiskingdomdesigns.no/", "type": 301 },
      { "source": "/butikk.html", "destination": "https://www.hiskingdomdesigns.no/", "type": 301 }
    ],
    "rewrites": [
      {
        "source": "/api/facebook-feed",
        "function": "facebookFeed"
      },
      {
        "source": "/seoSuggest",
        "function": "seoSuggest"
      }
    ]
  }
}

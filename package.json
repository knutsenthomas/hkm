{
    "name": "hiskingdomministry",
    "private": true,
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "dev": "npm run watch:css & npm run dev:vite",
        "dev:vite": "vite",
        "build": "npm run build:css && vite build",
        "build:css": "tailwindcss -i ./input.css -o ./styles.css --minify",
        "watch:css": "tailwindcss -i ./input.css -o ./styles.css --watch",
        "preview": "vite preview",
        "emulators:wix": "firebase emulators:start --only functions",
        "dev:butikk": "npm run watch:css & npm run dev:vite & npm run emulators:wix"
    },
    "devDependencies": {
        "tailwindcss": "^3.4.1",
        "vite": "^5.0.0"
    },
    "dependencies": {
        "@wix/sdk": "^1.21.3",
        "@wix/stores": "^1.0.702",
        "jsdom": "^28.1.0"
    }
}
